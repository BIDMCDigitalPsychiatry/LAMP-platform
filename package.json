{
  "name": "lamp-platform",
  "version": "0.0.0",
  "private": true,
  "overrides": {
    "@docusaurus/*": "3.7.0"
  },
  "scripts": {
    "docusaurus": "docusaurus",
    "sync:publications": "node scripts/sync-publications.mjs",
    "sync:projects": "node scripts/sync-projects.mjs",
    "sync:all": "npm run sync:publications && npm run sync:projects",
    "prestart": "echo 'Notion sync disabled - see CLAUDE.md Known Issues'",
    "prebuild": "echo 'Notion sync disabled - see CLAUDE.md Known Issues'",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "csv-parse": "^5.5.6",
    "@docusaurus/core": "3.7.0",
    "@docusaurus/plugin-content-docs": "3.7.0",
    "@docusaurus/plugin-client-redirects": "3.7.0",
    "@docusaurus/preset-classic": "3.7.0",
    "@easyops-cn/docusaurus-search-local": "^0.45.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "docusaurus-plugin-openapi": "^0.7.6",
    "docusaurus-preset-openapi": "^0.7.5",
    "docusaurus-theme-openapi": "^0.7.6",
    "prism-react-renderer": "^2.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.7.0",
    "@docusaurus/tsconfig": "^3.7.0",
    "@docusaurus/types": "3.7.0",
    "typescript": "~5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  },
  "docusaurus": {
    "title": "mindLAMP",
    "tagline": "One platform. Infinite configurations.",
    "url": "https://docs.lamp.digital",
    "favicon": "/img/logo.svg",
    "organizationName": "BIDMCDigitalPsychiatry",
    "projectName": "LAMP-platform",
    "baseUrl": "/",
    "onBrokenLinks": "warn",
    "onDuplicateRoutes": "warn",
    "onBrokenMarkdownLinks": "warn",
    "themeConfig": {
      "defaultMode": "light",
      "disableSwitch": false,
      "respectPrefersColorScheme": true,
      "image": "img/logo.svg",
      "announcementBar": {
        "id": "blog_subscribe_v2",
        "content": "📬 Want to stay updated? <a href=\"/blog/atom.xml\" target=\"_blank\" rel=\"noopener noreferrer\">Subscribe to our blog</a> to get notified when we publish new posts!",
        "backgroundColor": "#e8f2ff",
        "textColor": "#1a3a5c",
        "isCloseable": true
      },
      "languageTabs": [
        {
          "tabName": "cURL",
          "highlight": "bash",
          "language": "curl",
          "variant": "curl",
          "options": {
            "longFormat": false,
            "followRedirect": true,
            "trimRequestBody": true
          }
        }
      ],
      "navbar": {
        "title": "mindLAMP",
        "hideOnScroll": false,
        "logo": {
          "alt": "mindLAMP",
          "src": "img/logo.svg"
        },
        "items": [
          {
            "type": "dropdown",
            "label": "Capabilities",
            "position": "left",
            "items": [
              { "label": "Engage Participants", "to": "/capabilities/experience" },
              { "label": "Collect Rich Data", "to": "/capabilities/collect" },
              { "label": "Monitor Engagement", "to": "/capabilities/monitor" },
              { "label": "Analyze & Visualize", "to": "/capabilities/analyze" },
              { "label": "Customize & Scale", "to": "/capabilities/configure" }
            ]
          },
          {
            "label": "Docs",
            "position": "left",
            "to": "/docs"
          },
          {
            "label": "Projects",
            "position": "left",
            "to": "/projects"
          },
          {
            "label": "Publications",
            "position": "left",
            "to": "/publications"
          },
          {
            "label": "API",
            "position": "left",
            "to": "/api"
          },
          {
            "label": "Get Started",
            "position": "left",
            "to": "/get-started",
            "className": "navbar-bold"
          },
          {
            "label": "Privacy",
            "position": "right",
            "to": "/privacy"
          },
          {
            "type": "dropdown",
            "label": "Community",
            "position": "right",
            "items": [
              {
                "label": "Blog",
                "to": "/blog"
              },
              {
                "label": "GitHub",
                "href": "https://github.com/BIDMCDigitalPsychiatry"
              },
              {
                "label": "Lab Website",
                "href": "https://www.digitalpsych.org"
              },
              {
                "label": "Contact Us",
                "href": "mailto:team@digitalpsych.org"
              }
            ]
          }
        ]
      },
      "footer": {
        "style": "light",
        "links": [
                    {
            "label": "Blog",
            "to": "/blog"
          },
          {
            "label": "GitHub",
            "href": "https://github.com/BIDMCDigitalPsychiatry"
          },
          {
            "label": "Lab Website",
            "href": "https://www.digitalpsych.org"
          },
          {
            "label": "Contact Us",
            "href": "mailto:team@digitalpsych.org"
          }
        ],
        "copyright": "Copyright © 2026 <a href=\"https://www.digitalpsych.org\" target=\"_blank\" rel=\"noopener noreferrer\">Division of Digital Psychiatry @ BIDMC</a>"
      }
    },
    "presets": [
      [
        "@docusaurus/preset-classic",
        {
          "docs": {
            "sidebarPath": "./sidebars.ts",
            "routeBasePath": "/",
            "showLastUpdateAuthor": false,
            "showLastUpdateTime": false,
            "editUrl": "https://github.com/BIDMCDigitalPsychiatry/LAMP-platform/edit/master/"
          },
          "blog": {
            "showReadingTime": true,
            "blogTitle": "mindLAMP Blog",
            "blogDescription": "Updates, tutorials, and news from the mindLAMP team",
            "feedOptions": {
              "type": ["rss", "atom"],
              "xslt": true
            },
            "onInlineTags": "warn",
            "onInlineAuthors": "warn",
            "onUntruncatedBlogPosts": "warn"
          },
          "theme": {
            "customCss": "./src/css/custom.css"
          }
        }
      ]
    ],
    "themes": ["docusaurus-theme-openapi"],
    "plugins": [
      [
        "docusaurus-plugin-openapi",
        {
          "id": "api",
          "path": "./LAMP-protocol/openapi.yml",
          "routeBasePath": "api"
        }
      ],
      [
        "@easyops-cn/docusaurus-search-local",
        {
          "indexDocs": true,
          "indexBlog": true,
          "indexPages": true,
          "hashed": true
        }
      ],
          [
      "@docusaurus/plugin-client-redirects",
      {
        "redirects": [
          { "from": "/start_here/overview", "to": "/app" },
          { "from": "/data_science/intro", "to": "/developer/api-sdks/introduction" },
